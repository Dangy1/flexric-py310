    import uvicorn

    uvicorn.run(
        "flexric_agent_portal:app",
        host=os.getenv("FLEXRIC_AGENT_PORTAL_HOST", "127.0.0.1"),
        port=int(os.getenv("FLEXRIC_AGENT_PORTAL_PORT", "8088")),
        reload=False,
        access_log=False,
    )
